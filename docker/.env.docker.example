# ─── Team Board – Docker Umgebungsvariablen ───────────────────────────────────
# Datei kopieren: cp docker/.env.docker.example docker/.env.docker
# Dann starten:   docker compose -f docker/docker-compose.yml --env-file docker/.env.docker up -d

# PFLICHTFELD: Mindestens 32 zufällige Zeichen
# Generieren: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ersetze-mich-durch-einen-langen-zufaelligen-wert

# Frontend-URL (für CORS-Header im Backend-Log)
CORS_ORIGIN=https://localhost

# Ports auf dem Host (optional – Standard: 443)
# HTTPS_PORT=443
