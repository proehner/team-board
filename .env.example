# ─── Frontend environment variables (Vite) ───────────────────────────────────
# All variables must be prefixed with VITE_ to be accessible in the browser.
# For local development: copy this file to .env.local and adjust as needed.

# Backend URL for GitHub Pages deployments.
# Leave empty for local development (Vite proxy handles forwarding).
# Example: VITE_API_URL=https://team-lead.myserver.com
VITE_API_URL=

# Base path of the frontend.
# Leave empty for local development or deployment as a root site.
# Automatically set by CI during GitHub Pages builds (/<repo-name>/).
VITE_BASE_PATH=
