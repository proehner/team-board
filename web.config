<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS-Konfiguration für Team Board App (iisnode)
  Voraussetzungen:
    - iisnode installiert (https://github.com/Azure/iisnode/releases)
    - URL Rewrite Modul installiert
    - npm run build && npm run server:build ausgeführt

  Pfad bei DB_PATH an tatsächliche Installation anpassen!
-->
<configuration>
  <system.webServer>

    <handlers>
      <add name="iisnode"
           path="server/dist/index.js"
           verb="*"
           modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- API-Anfragen direkt an Node.js weiterleiten -->
        <rule name="NodeAPI" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="server/dist/index.js" />
        </rule>

        <!-- Vorhandene statische Dateien (dist/) direkt ausliefern -->
        <rule name="StaticFiles" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- Alle anderen Anfragen (SPA-Routing) an Node.js -->
        <rule name="SPA">
          <match url=".*" />
          <action type="Rewrite" url="server/dist/index.js" />
        </rule>
      </rules>
    </rewrite>

    <iisnode
      nodeProcessCommandLine="node"
      watchedFiles="*.js"
      loggingEnabled="true"
      logDirectory="iisnode-logs"
      debuggingEnabled="false"
      maxConcurrentRequestsPerProcess="1024" />

    <httpErrors existingResponse="PassThrough" />

    <staticContent>
      <mimeMap fileExtension=".js"   mimeType="application/javascript" />
      <mimeMap fileExtension=".mjs"  mimeType="application/javascript" />
      <mimeMap fileExtension=".css"  mimeType="text/css" />
      <mimeMap fileExtension=".svg"  mimeType="image/svg+xml" />
      <mimeMap fileExtension=".wasm" mimeType="application/wasm" />
    </staticContent>

  </system.webServer>

  <appSettings>
    <!--
      PORT: TCP-Port des Node.js-Servers (iisnode ignoriert diesen, da IIS die Verbindung verwaltet)
      DB_PATH: Absoluter Pfad zur SQLite-Datenbankdatei – ANPASSEN!
    -->
    <add key="PORT"    value="3001" />
    <add key="DB_PATH" value="C:\inetpub\wwwroot\team-lead\server\data\teamlead.db" />
  </appSettings>
</configuration>
