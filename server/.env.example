# JWT-Secret (zwingend erforderlich – mindestens 32 zufällige Zeichen)
# Generieren: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ersetze-mich-durch-einen-langen-zufaelligen-wert

# Erlaubte CORS-Herkunft (Frontend-URL)
# Entwicklung: http://localhost:5173
# Produktion:  https://mein-server.intern
CORS_ORIGIN=http://localhost:5173

# Server-Port (optional, Standard: 3001)
# PORT=3001

# ─── E-Mail / SMTP (optional) ────────────────────────────────────────────────
# Wird für @Mention-Benachrichtigungen in Kommentaren benötigt.
# Ohne diese Konfiguration werden keine Mails versendet.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false          # true für Port 465 (SSL)
# SMTP_USER=user@example.com
# SMTP_PASS=geheimes-passwort
# SMTP_FROM=noreply@example.com
