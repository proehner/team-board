# JWT secret (required – at least 32 random characters)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-value

# Allowed CORS origin (frontend URL)
# Development: http://localhost:5173
# Production:  https://my-server.internal
CORS_ORIGIN=http://localhost:5173

# Server port (optional, default: 3001)
# PORT=3001

# ─── Email / SMTP (optional) ─────────────────────────────────────────────────
# Required for @mention notifications in comments.
# Without this configuration no emails will be sent.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false          # true for port 465 (SSL)
# SMTP_USER=user@example.com
# SMTP_PASS=secret-password
# SMTP_FROM=noreply@example.com
