# See http://help.github.com/ignore-files/ for more about ignoring files.

# Environment (enthält Secrets – niemals einchecken)
.env.local
.env.*.local
/server/.env

# Build
/dist
/server/dist
/release
/update

# Dependencies
/node_modules
/server/node_modules

# Database
/server/data/uploads
/server/data/*.db
/server/data/*.db.lock
/server/data/*.db.backup-*
/server/data/azure-ranking.*.json

# Docker
/docker/.env.docker
/docker/nginx/ssl/*.pem

# IDE
/.claude/*
/.vscode/*
!/.vscode/extensions.json
!/.vscode/launch.json
!/.vscode/settings.json
!/.vscode/spellright.dict
!/.vscode/tasks.json
